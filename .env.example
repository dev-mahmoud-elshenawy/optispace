# Copy this file to .env and fill in your own values. .env is gitignored — your
# secrets stay on your machine and are never pushed.

# ── Database ────────────────────────────────────────────────────────────────
# Local SQLite file (default). Path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# ── Azure DevOps sync (optional) ─────────────────────────────────────────────
# Pulls work items assigned to you into Tasks. Leave AZURE_DEVOPS_PAT blank to
# disable the integration. Per-user config — never commit your real PAT.
#
# Create a PAT at: https://dev.azure.com/<your-org>/_usersSettings/tokens
# Scopes required: "Work Items (Read)" + "Project and Team (Read)".
AZURE_DEVOPS_ORG_URL="https://dev.azure.com/your-org"
AZURE_DEVOPS_PAT=""
# Optional — display/fallback only; WIQL @me already resolves to the PAT owner.
AZURE_DEVOPS_EMAIL="you@example.com"
# Which projects to sync: "all" for every accessible project, or a comma-separated
# list of project names. Blank = sync nothing (explicit opt-in — no "blank = all").
AZURE_DEVOPS_PROJECTS="all"
# Import completed/closed items too? Default false (only open work items).
AZURE_DEVOPS_INCLUDE_DONE="false"

# ── GitHub pull requests (optional) ──────────────────────────────────────────
# Surfaces PRs you authored or were asked to review. Leave GITHUB_TOKEN blank to
# disable. Per-user config — never commit your real token.
#
# Create a fine-grained token at: https://github.com/settings/tokens
# Scope required: "Pull requests" (Read-only). For private org repos, also grant
# the org access under the token's "Resource owner".
GITHUB_TOKEN=""
# Which repos to sync: "all" for every repo the token can see, or a comma-separated
# list of "owner/repo". Blank = sync nothing (explicit opt-in — no "blank = all").
GITHUB_REPOS="all"
# Optional: comma-separated org logins to also include YOUR PRs from (authored /
# review-requested / assigned) even when GITHUB_REPOS is a specific list. Only PRs
# you're involved in ever show — never other people's. Redundant when GITHUB_REPOS
# is "all". Needs a token that can see the org (classic token, repo + read:org).
GITHUB_ORGS=""

# ── Calendar (optional) ──────────────────────────────────────────────
# Published ICS feed for your Outlook/Teams calendar. In Outlook:
# Settings → Calendar → Shared calendars → Publish a calendar → copy the ICS link.
# Leave blank to disable. Powers the /calendar agenda + today's meetings on the dashboard.
CALENDAR_ICS_URL=""
# Minutes before a meeting starts to fire a "starting soon" reminder (desktop push +
# notification). Default 15. Only fires while the app is open (local-first, no scheduler).
CALENDAR_REMINDER_MINUTES="15"
