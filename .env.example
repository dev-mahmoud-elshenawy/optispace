# Copy this file to .env and fill in your own values. .env is gitignored — your
# secrets stay on your machine and are never pushed.

# ── Database ────────────────────────────────────────────────────────────────
# Local SQLite file (default). Path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# ── Integrations: no .env needed ─────────────────────────────────────────────
# Azure DevOps, Calendar (ICS), and GitHub are all configured in the app under
# Settings → Integrations, and stored in the local SQLite DB (this device only).
# Nothing to set here:
#   • Azure DevOps — org URL, PAT, email, projects, include-done
#   • Calendar     — published ICS feed URL + reminder minutes
#   • GitHub       — OAuth device flow (or paste a token)
# DATABASE_URL above is the only variable this app reads from .env.
