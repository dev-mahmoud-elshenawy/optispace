// OptiSpace — local-first personal workspace
// SQLite has no native enums or scalar-list columns, so:
//   - enum-like fields are String columns validated by Zod (see src/types)
//   - tags are stored as a JSON string ("[]") and parsed in the service layer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Annual Leave ─────────────────────────────────────────────
model LeaveAllowance {
  id        String   @id @default(cuid())
  year      Int      @unique
  totalDays Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Leave {
  id        String   @id @default(cuid())
  startDate DateTime
  endDate   DateTime
  type      String // annual (see LEAVE_TYPES in src/types)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([startDate])
}

// ── Profiles Hub ─────────────────────────────────────────────
model Profile {
  id        String   @id @default(cuid())
  label     String
  url       String
  username  String?
  icon      String? // lucide icon key, e.g. "github"
  order     Int      @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ── Development Progress ─────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  name        String
  repoUrl     String?
  platform    String // flutter | react_native | web | backend
  status      String // planning | active | paused | completed | production
  pinned      Boolean  @default(false) // bookmarked → sorts to the top of Development
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  milestones Milestone[]
  tasks      Task[]
  packages   Package[]
  files      ProjectFile[]
  links      ProjectLink[]
  feedback   ProjectFeedback[]
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  title     String
  done      Boolean  @default(false)
  dueDate   DateTime?
  order     Int      @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ── Task Management ──────────────────────────────────────────
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo") // todo | in_progress | done
  priority    String    @default("medium") // low | medium | high
  dueDate     DateTime?
  source        String? // external origin, e.g. "azure_devops" (null = created in-app)
  externalId    String? // id in the source system, unique per source
  externalUrl   String? // link back to the source item
  workItemType  String? // ADO System.WorkItemType, e.g. "Bug"/"Task"/"User Story" (source-owned)
  adoState      String? // raw ADO System.State, e.g. "New"/"Ready For Testing"/"In Test" (source-owned; shown in list)
  adoPriority   Int? // raw ADO Microsoft.VSTS.Common.Priority (1–4) for the card flag (source-owned)
  iterationPath String? // ADO sprint path, e.g. "Canitude\Iteration 2" (source-owned)
  effort        Float? // ADO estimated effort / original estimate (source-owned; null = unestimated)
  changedDate   DateTime? // ADO System.ChangedDate — last change in the source (source-owned)
  order       Int       @default(0) // position within its Kanban column
  projectId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  subtasks Subtask[]

  @@unique([source, externalId])
  @@index([status])
  @@index([projectId])
}

model Subtask {
  id        String    @id @default(cuid())
  taskId    String
  title     String
  done      Boolean   @default(false)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ── Notifications (Azure DevOps assignments & mentions) ──────
model Notification {
  id         String    @id @default(cuid())
  type       String // "assigned" | "mentioned"
  externalId String // ADO work item id
  title      String // work item title (for display)
  url        String // deep link to the ADO work item
  message    String? // e.g. "Assigned to you" or a comment snippet
  project    String? // ADO project name (shown as the notification title)
  actor      String? // who mentioned / assigned me (display name)
  occurredAt DateTime? // when the mention/assignment happened in ADO (vs createdAt = detected)
  dedupeKey  String    @unique // "assigned:{externalId}" | "mention:{externalId}:{commentId}"
  readAt     DateTime?
  notifiedAt DateTime? // set once the browser desktop popup has fired
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  @@index([readAt])
  @@index([createdAt])
}

// ── Calendar cache (synced from the ICS feed) ────────────────
// Expanded occurrences within a rolling window, refreshed by syncCalendar.
// fingerprint lets sync update only rows whose content actually changed.
model CalendarEvent {
  id          String    @id @default(cuid())
  dedupeKey   String    @unique // uid + occurrence start
  title       String
  start       DateTime
  end         DateTime
  location    String?
  meetingUrl  String? // Teams/Zoom/Meet join link extracted from the ICS event
  organizer   String?
  attendees   String    @default("[]") // JSON array of display names
  allDay      Boolean   @default(false)
  fingerprint String // hash of content fields → skip unchanged rows
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([start])
}

// ── GitHub pull requests (synced cache) ──────────────────────
// PRs you authored or were asked to review, refreshed by syncGithubPullRequests.
// Soft-deleted when they leave the open @me result set (merged/closed/reassigned).
model GithubPullRequest {
  id              String    @id @default(cuid())
  nodeId          String? // GitHub GraphQL global node ID — fetch detail by this (survives repo renames / name-resolution quirks)
  repo            String // "owner/repo"
  number          Int
  title           String
  url             String
  state           String // open | merged | closed
  draft           Boolean   @default(false)
  author          String
  reviewDecision  String? // APPROVED | CHANGES_REQUESTED | REVIEW_REQUIRED
  checksStatus    String? // SUCCESS | FAILURE | PENDING | ERROR | EXPECTED
  headBranch      String
  baseBranch      String
  updatedAtRemote DateTime // GitHub updatedAt — for status_changed diffing
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@unique([repo, number])
  @@index([state])
}

// OAuth device-flow token for GitHub — single row (id = "singleton"). When present it
// takes precedence over the GITHUB_TOKEN PAT in .env; disconnecting deletes the row and
// falls back to the PAT (if any). login = the authenticated user, shown in Settings.
model GithubAuth {
  id          String   @id @default("singleton")
  accessToken String
  scope       String?
  login       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Azure DevOps connection config — set in Settings (no .env). Single row (id="singleton").
model AdoConfig {
  id          String   @id @default("singleton")
  orgUrl      String?
  pat         String?
  email       String?
  projects    String   @default("") // "all" or a comma-separated list of project names
  includeDone Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Calendar (published ICS feed) config — set in Settings (no .env). Single row (id="singleton").
model CalendarConfig {
  id              String   @id @default("singleton")
  icsUrl          String?
  reminderMinutes Int      @default(15)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Packages ─────────────────────────────────────────────────
// Cache of Azure DevOps projects the PAT can access, so the "create in DevOps" picker
// is instant. Refreshed on each sync (syncAzureDevOpsProjects); soft-deleted when a
// project leaves the accessible set.
model AdoProject {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([name])
}

model Package {
  id             String  @id @default(cuid())
  name           String
  description    String?
  registry       String // npm | pubdev
  registryUrl    String?
  githubUrl      String?
  language       String // dart_flutter | js_react | js_react_native
  currentVersion String?
  tags           String  @default("[]") // JSON array of strings
  status         String  @default("active") // active | maintenance | deprecated
  projectId      String?

  // cached registry stats — populated by the manual "Refresh stats" action and the
  // daily background poller (packages not synced in >24h)
  latestVersion   String?
  weeklyDownloads Int?
  likes           Int?
  pubPoints       Int?
  vulnerable      Boolean   @default(false) // any known OSV.dev advisory for currentVersion
  advisoryUrl     String?
  lastSyncedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([registry])
}

// ── Project File Storage ─────────────────────────────────────
// Dynamic per-project vault for reference files (.env, keystores, prod configs).
// Bytes are stored inline in the DB — fine for small config files on a local,
// single-user app. Do NOT commit prisma/dev.db; these contents are unencrypted.
model ProjectFile {
  id        String    @id @default(cuid())
  projectId String
  name      String
  mimeType  String    @default("application/octet-stream")
  size      Int       @default(0)
  data      Bytes
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ── Project Links (releases, dashboards, servers, repos) ─────
// Optional username/secret let a dashboard/server link carry its login.
model ProjectLink {
  id        String    @id @default(cuid())
  projectId String
  label     String
  url       String
  type      String    @default("other") // release | dashboard | server | repo | design | other
  username  String?
  secret    String?
  notes     String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ── Project Client Feedback ──────────────────────────────────
model ProjectFeedback {
  id        String    @id @default(cuid())
  projectId String
  message   String
  from      String?
  release   String? // the release / features / sprint this feedback is about
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  attachments FeedbackAttachment[]

  @@index([projectId])
}

// ── Feedback Attachments (multiple docs per feedback) ────────
model FeedbackAttachment {
  id         String   @id @default(cuid())
  feedbackId String
  name       String
  mimeType   String   @default("application/octet-stream")
  data       Bytes
  createdAt  DateTime @default(now())

  feedback ProjectFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}
