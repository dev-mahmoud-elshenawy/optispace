# Copy this file to .env and fill in your own values. .env is gitignored — your
# secrets stay on your machine and are never pushed.

# ── Database ────────────────────────────────────────────────────────────────
# Local SQLite file (default). Path is relative to the prisma/ directory.
DATABASE_URL="file:./dev.db"

# ── Azure DevOps sync (optional) ─────────────────────────────────────────────
# Pulls work items assigned to you into Tasks. Leave AZURE_DEVOPS_PAT blank to
# disable the integration. Per-user config — never commit your real PAT.
#
# Create a PAT at: https://dev.azure.com/<your-org>/_usersSettings/tokens
# Scopes required: "Work Items (Read)" + "Project and Team (Read)".
AZURE_DEVOPS_ORG_URL="https://dev.azure.com/your-org"
AZURE_DEVOPS_PAT=""
# Optional — display/fallback only; WIQL @me already resolves to the PAT owner.
AZURE_DEVOPS_EMAIL="you@example.com"
# Comma-separated project names to sync. Leave blank to sync all accessible projects.
AZURE_DEVOPS_PROJECTS=""
# Import completed/closed items too? Default false (only open work items).
AZURE_DEVOPS_INCLUDE_DONE="false"

# ── Calendar (optional) ──────────────────────────────────────────────
# Published ICS feed for your Outlook/Teams calendar. In Outlook:
# Settings → Calendar → Shared calendars → Publish a calendar → copy the ICS link.
# Leave blank to disable. Powers the /calendar agenda + today's meetings on the dashboard.
CALENDAR_ICS_URL=""
